#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            display-name = "Base";
            bindings = <
                &kp KP_N7  &kp KP_N8     &kp KP_N9
                &kp KP_N4  &kp KP_N5     &kp KP_N6
                &kp KP_N1  &kp KP_N2     &lt 1 KP_N3  /* 短押しで3、長押しでレイヤー1へ */
                &kp KP_N0  &none         &none
            >;

            sensor-bindings = <&inc_dec_kp PG_UP PG_DN>;
        };

        layer_1 {
            display-name = "FCP1";
            bindings = <
                &kp LG(LC(PLUS))  &kp LS(Z)  &kp LG(MINUS)
                &kp LEFT          &none      &kp RIGHT
                &tog 2            &kp SPACE  &tog 0        /* ベースへ戻る */
                &kp LEFT_SHIFT
            >;
            sensor-bindings = <&inc_dec_kp LS(LEFT) LS(RIGHT)>;
        };

        layer_2 {
            display-name = "FCP2";
            bindings = <
                &trans  &trans  &trans
                &trans  &trans  &trans
                &tog 3  &tog 1  &tog 0        /* ベースへ戻る */
                &trans
            >;
        };

        layer_3 {
            display-name = "BT";
            bindings = <
                &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_CLR_ALL
                &trans        &trans        &trans
                &trans        &trans        &tog 0        /* ベースへ戻る */
                &trans
            >;
        };
    };
};
