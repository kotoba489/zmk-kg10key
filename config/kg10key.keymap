default_layer {
            // 横4個 × 縦5行 = 20個の定義
            bindings = <
&kp ESC   &kp TAB   &kp BSPC  &kp SLASH
&kp N7    &kp N8    &kp N9    &kp STAR
&kp N4    &kp N5    &kp N6    &kp MINUS
&kp N1    &kp N2    &kp N3    &kp PLUS
&mo 1     &kp N0    &kp DOT   &kp ENTER
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_UP C_VOL_DN>;
        };
