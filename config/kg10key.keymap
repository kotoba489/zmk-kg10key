bindings = <
                &kp KP_N7    &kp KP_N8    &kp KP_N9    /* Row 0: 7, 8, 9 */
                &kp KP_N4    &kp KP_N5    &kp KP_N6    /* Row 1: 4, 5, 6 */
                &kp KP_N1    &kp KP_N2    &kp KP_N3    /* Row 2: 1, 2, 3 */
                &kp KP_N0                              /* Row 3: 0 (左端のみ) */
            >;
