#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    // エンコーダーの定義（画像に基づき9と10を使用）
    encoder: encoder {
        compatible = "alps,ec11";
        label = "ROTARY_ENCODER";
        a-gpios = <&xiao_d 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>; // パッド9
        b-gpios = <&xiao_d 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>; // パッド10
        steps = <80>; 
    };

    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        columns = <3>;
        rows = <4>;
        map = <
            RC(0,0) RC(0,1) RC(0,2)  /* 7, 8, 9 */
            RC(1,0) RC(1,1) RC(1,2)  /* 4, 5, 6 */
            RC(2,0) RC(2,1) RC(2,2)  /* 1, 2, 3 */
            RC(3,0)                  /* 0 */
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        label = "KSCAN";
        diode-direction = "col2row";

        col-gpios
            = <&xiao_d 4 GPIO_ACTIVE_HIGH>  /* COL0 */
            , <&xiao_d 5 GPIO_ACTIVE_HIGH>  /* COL1 */
            , <&xiao_d 11 GPIO_ACTIVE_HIGH> /* COL2 (画像通りのD11へ修正) */
            ;

        row-gpios
            = <&xiao_d 0 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* Row0 */
            , <&xiao_d 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* Row1 */
            , <&xiao_d 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* Row2 */
            , <&xiao_d 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)> /* Row3 */
            ;
    };
};
